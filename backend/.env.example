# Backend environment variables
# .env (à ajouter à .gitignore)

# N8N Configuration
N8N_BASE_URL=https://ikramkanouz.app.n8n.cloud
N8N_WEBHOOK_TOKEN=your_webhook_token_here

# Database Configuration (exemple)
DATABASE_URL=postgresql://user:password@localhost/allodoc

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
